<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.stanley.ai-glasses.auto-convert</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>/Users/stanley/AI Glasses/scripts/auto_convert_clips.sh</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>StartInterval</key>
  <integer>10</integer>

  <key>StandardOutPath</key>
  <string>/Users/stanley/Library/Logs/ai-glasses-auto-convert.launchd.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/stanley/Library/Logs/ai-glasses-auto-convert.launchd.err.log</string>
</dict>
</plist>
